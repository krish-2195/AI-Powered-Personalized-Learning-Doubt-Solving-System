# Application Settings
APP_NAME=AI Learning Platform
DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production-make-it-very-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=learning_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=learning_platform

# AI/ML API Keys
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Model Directories
MODEL_DIR=./ml_models/saved_models

# Frontend environment
# Point to your backend FastAPI server
VITE_API_URL=http://localhost:8000
